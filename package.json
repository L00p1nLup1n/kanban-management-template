{
  "name": "react-app-kanbanboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "dev:frontend": "vite --open",
    "dev:backend": "npm --prefix src/server run dev",
    "start:backend": "npm --prefix src/server start",
    "backend:init-db": "npm --prefix src/server run init-db",
    "backend:test-connection": "npm --prefix src/server run test-connection",
    "backend:test-api": "npm --prefix src/server run test-api",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.0.8",
    "@chakra-ui/react": "^2.2.6",
    "@emotion/react": "^11.10.0",
    "@emotion/styled": "^11.10.0",
    "axios": "^1.13.2",
    "framer-motion": "^6.5.1",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.1",
    "react-textarea-autosize": "^8.3.4",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.7.2",
    "usehooks-ts": "^2.6.0",
    "uuid": "^8.3.2",
    "vite-plugin-eslint": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^18.7.8",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.33.0",
    "@typescript-eslint/parser": "^5.33.0",
    "@vitejs/plugin-react": "^2.0.1",
    "eslint": "^8.22.0",
    "eslint-config-airbnb-typescript-prettier": "^5.0.0",
    "eslint-plugin-jest": "^26.8.3",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-unicorn": "^43.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "lodash": "^4.17.21",
    "prettier": "2.7.1",
    "typescript": "^4.6.4",
    "vite": "^3.0.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
